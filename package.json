{
  "name": "adminpanel",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "client": "vite",
    "server": "cd Backend && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "vite build",
    "start": "npm --prefix Backend start",
    "postinstall": "cd Backend && npm install --ignore-scripts"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@vitejs/plugin-react": "^4.3.4",
    "axios": "^1.15.1",
    "chart.js": "^4.5.1",
    "concurrently": "^9.2.1",
    "react": "^19.2.5",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.5",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0",
    "vite": "^5.4.19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "nodemon": "^3.1.14"
  }
}
